{%- liquid
  assign bg_desktop = section.settings.bg_image_desktop
  assign bg_mobile = section.settings.bg_image_mobile
  assign bg_desktop_url = ''
  assign bg_mobile_url = ''
  if bg_desktop != blank
    assign bg_desktop_url = bg_desktop | image_url: width: 3840
  endif
  if bg_mobile != blank
    assign bg_mobile_url = bg_mobile | image_url: width: 2000
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .ll-science-stats-section {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }} !important; 
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    height:460px;
    {%- if bg_mobile_url != '' -%}
      background-image: url('{{ bg_mobile_url }}');
    {%- elsif bg_desktop_url != '' -%}
      background-image: url('{{ bg_desktop_url }}');
    {%- endif -%}
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .ll-science-stats-section {
          height:670px;
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      {%- if bg_desktop_url != '' -%}
        background-image: url('{{ bg_desktop_url }}');
      {%- elsif bg_mobile_url != '' -%}
        background-image: url('{{ bg_mobile_url }}');
      {%- else -%}
        background-image: none;
      {%- endif -%}
    }
  }
{%- endstyle -%}

<div class="ll-science-stats-section">
  <div class="page-width">
    <div class="ll-science-stats-intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="ll-science-stats-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="ll-science-stats-subheading rte">{{ section.settings.subheading }}</div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ll-science-stats-grid">
        {%- for block in section.blocks -%}
          <div class="ll-science-stats-block" {{ block.shopify_attributes }}>
            {%- if block.settings.stat_heading != blank -%}
              <p class="ll-science-stats-block-heading">{{ block.settings.stat_heading }}</p>
            {%- endif -%}
            {%- if block.settings.stat_subheading != blank -%}
              <div class="ll-science-stats-block-subheading rte">{{ block.settings.stat_subheading }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% style %}
  .ll-science-stats-section .page-width {
    max-width: 100%;
  }

  .ll-science-stats-intro {
    text-align: center;
    max-width: 880px;
    margin: 0 auto 40px; 
  } 

  @media screen and (min-width: 769px) {
    .ll-science-stats-intro {
      margin-bottom: 100px;
    }
  }

.ll-science-stats-heading {
    font-size: 28px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.82px;
    margin: 0 0 15px;
    color: {{ section.settings.text_color }} !important; 
} 

  .ll-science-stats-subheading p{
font-style: normal;
font-weight: 400;
font-size: 18px;
line-height: 30px;
    color: {{ section.settings.text_color }} !important; 
  }

  @media screen and (min-width: 769px) {
    .ll-science-stats-heading {
    font-size: 40px; 
    margin: 0 0 40px; 
}
    .ll-science-stats-subheading {
      font-size: 18px;
    }
  }

 

  .ll-science-stats-subheading p:last-child {
    margin-bottom: 0;
  }

  .ll-science-stats-grid {
    display: grid;
     gap: 32px;
       grid-template-columns: repeat(3, 1fr);
    text-align: center;
  }

  @media screen and (min-width: 769px) {
    .ll-science-stats-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      align-items: start;
    }
  }

  .ll-science-stats-block-heading {
font-style: normal;
font-weight: 400;
font-size: 24px; 
line-height: 1.1;
letter-spacing: -0.816832px;
    margin: 0 0 10px;
    color: {{ section.settings.text_color }} !important; 
  }

  .ll-science-stats-block-subheading p {
font-style: normal;
font-weight: 400;
font-size: 14px; 
line-height: 1.6; 
 text-align: center;
letter-spacing: -0.777771px;
 margin: 0;
    color: {{ section.settings.text_color }} !important; 
  }

  @media screen and (min-width: 769px) {
      .ll-science-stats-block-heading { 
font-size: 80px;  
  margin: 0 0 18px;
  }
  .ll-science-stats-block-subheading p { 
font-size: 20px;
  }
  }

 
{% endstyle %}

{% schema %}
{
  "name": "LL Science stats",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Uses desktop image on mobile if empty."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0B0F1A",
      "info": "Shows behind or instead of images."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Creatine backed by science"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>One of the most studied supplements, proven to support strength, performance, and recovery by helping your body produce more energy during workouts.</p>"
    },
    {
      "type": "header",
      "content": "Padding — desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding — mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_heading",
          "label": "Heading",
          "default": "+15%",
          "info": "Large stat or label (e.g. +15%, +2–5 lbs)."
        },
        {
          "type": "richtext",
          "id": "stat_subheading",
          "label": "Subheading",
          "default": "<p>Increase in strength and power output</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LL Science stats",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_heading": "+15%",
            "stat_subheading": "<p>Increase in strength and power output</p>"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_heading": "+2–5 lbs",
            "stat_subheading": "<p>Typical lean mass gains in training studies</p>"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_heading": "1000+",
            "stat_subheading": "<p>Peer-reviewed studies on creatine supplementation</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
