          <button type="button" class="ll2-arrow" id="ll2-prev-{{ section.id }}" aria-label="Previous">
            <svg width="27" height="27" viewBox="0 0 27 27" xmlns="http://www.w3.org/2000/svg">
              <path d="M23.848 13.1275H2.41211M2.41211 13.1275L13.1284 23.8438M2.41211 13.1275L13.1284 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button type="button" class="ll2-arrow" id="ll2-next-{{ section.id }}" aria-label="Next">
            <svg width="27" height="27" viewBox="0 0 27 27" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.41211 13.1275H23.848M23.848 13.1275L13.1317 23.8438M23.848 13.1275L13.1317 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}

      {% if section.settings.show_dots %}
        <div class="ll2-dots-wrapper" id="ll2-dots-{{ section.id }}"></div>
      {% endif %}

    {% endif %}
  </div>
</div>

<script>
(function () {
  var ID         = '{{ section.id }}';
  var sectionEl  = document.getElementById('ll2-section-' + ID);
  var sectionInView = false;
  var rafId      = null;

  /* ─────────────────────────────────────────
     VIDEO HELPERS
     All playback is managed entirely in JS.
     The autoplay attribute is stripped so the
     browser never auto-manages these videos.
  ───────────────────────────────────────── */
  function getVideos() {
    return sectionEl ? Array.prototype.slice.call(sectionEl.querySelectorAll('video')) : [];
  }

  function safePlay(v) {
    v.muted = true;
    if (v.paused) {
      var p = v.play();
      if (p && p.catch) p.catch(function () {});
    }
  }

  function safePause(v) {
    if (!v.paused) v.pause();
  }

  /* ─────────────────────────────────────────
     POLLING LOOP
     Runs via requestAnimationFrame, checks
     every 500 ms while section is visible.
     Any external pause (Dawn, media-gallery,
     etc.) is immediately reversed.
  ───────────────────────────────────────── */
  function startPolling() {
    if (rafId) return;
    var last = 0;
    function tick(ts) {
      if (ts - last >= 500) {
        last = ts;
        getVideos().forEach(safePlay);
      }
      rafId = sectionInView ? requestAnimationFrame(tick) : null;
    }
    rafId = requestAnimationFrame(tick);
  }

  function stopPolling() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    getVideos().forEach(safePause);
  }

  /* ─────────────────────────────────────────
     COVER OVERLAYS
  ───────────────────────────────────────── */
  function bindCovers() {
    if (!sectionEl) return;
    sectionEl.querySelectorAll('.ll2-item').forEach(function (item) {
      var video = item.querySelector('video');
      var cover = item.querySelector('.ll2-cover');
      if (!video || video.dataset.ll2Bound) return;
      video.dataset.ll2Bound = '1';
      video.muted = true;
      video.addEventListener('playing', function () { item.classList.add('playing'); });
      video.addEventListener('pause',   function () { item.classList.remove('playing'); });
      if (cover) {
        cover.addEventListener('click', function () { safePlay(video); });
      }
    });
  }

  /* ─────────────────────────────────────────
     INTERSECTION OBSERVER
  ───────────────────────────────────────── */
  function observeSection() {
    if (!sectionEl) return;
    new IntersectionObserver(function (entries) {
      sectionInView = entries[0].isIntersecting;
      if (sectionInView) startPolling();
      else stopPolling();
    }, { threshold: 0.1 }).observe(sectionEl);

    document.addEventListener('visibilitychange', function () {
      if (!document.hidden && sectionInView) startPolling();
      else if (document.hidden) stopPolling();
    });
  }

  /* ─────────────────────────────────────────
     INFINITE LOOP SLIDER
     Clones perPage slides from each end of
     the track. After each animated transition
     into clone territory, the position is
     silently reset to the matching real slide
     — creating a seamless infinite loop.
  ───────────────────────────────────────── */
  function initSlider() {
    var track    = document.getElementById('ll2-track-' + ID);
    var dotsWrap = document.getElementById('ll2-dots-' + ID);
    var prevBtn  = document.getElementById('ll2-prev-' + ID);
    var nextBtn  = document.getElementById('ll2-next-' + ID);
    if (!track) return;

    /* Store original (real) slides before any cloning */
    var realSlides    = Array.prototype.slice.call(track.children);
    var totalSlides   = realSlides.length;
    var desktopPer    = {{ section.settings.slides_to_show | json }};
    var mobilePer     = {{ section.settings.slides_to_show_mobile | json }};
    var doAutoplay    = {{ section.settings.autoplay | json }};
    var autoInterval  = {{ section.settings.autoplay_speed | json }};
    var currentIdx    = 0;   /* DOM index into track.children (includes clones) */
    var clonesAdded   = 0;   /* how many clone slides were prepended */
    var isBusy        = false;
    var autoTimer     = null;

    function perPage() {
      return window.innerWidth <= 749 ? mobilePer : desktopPer;
    }

    /* Pixel width of one slide based on current container size */
    function slideW() {
      return track.parentElement.offsetWidth / perPage();
    }

    /* ── Build clones ──
       Prepend clones of the last  N real slides.
       Append  clones of the first N real slides.
       N = perPage, capped to totalSlides.
    */
    function buildClones() {
      /* Remove any existing clones */
      Array.prototype.slice.call(
        track.querySelectorAll('[data-ll2-clone]')
      ).forEach(function (c) { track.removeChild(c); });

      clonesAdded = Math.min(perPage(), totalSlides);

      /* Prepend: clones of the LAST clonesAdded real slides */
      var frag = document.createDocumentFragment();
      for (var i = totalSlides - clonesAdded; i < totalSlides; i++) {
        var c = realSlides[i].cloneNode(true);
        c.setAttribute('data-ll2-clone', '1');
        c.setAttribute('aria-hidden', 'true');
        frag.appendChild(c);
      }
      track.insertBefore(frag, track.firstChild);

      /* Append: clones of the FIRST clonesAdded real slides */
      for (var j = 0; j < clonesAdded; j++) {
        var c2 = realSlides[j].cloneNode(true);
        c2.setAttribute('data-ll2-clone', '1');
        c2.setAttribute('aria-hidden', 'true');
        track.appendChild(c2);
      }

      /* Prepare clone videos — JS handles all playback */
      Array.prototype.slice.call(
        track.querySelectorAll('[data-ll2-clone] video')
      ).forEach(function (v) {
        v.removeAttribute('autoplay');
        v.muted = true;
      });

      /* Start at the first real slide */
      currentIdx = clonesAdded;
    }

    /* ── Apply position ── */
    function applyPos(animated) {
      track.style.transition = animated
        ? 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
        : 'none';
      track.style.transform = 'translateX(' + (-currentIdx * slideW()) + 'px)';
    }

    /* ── Resize all slides to current px width ── */
    function applyWidths() {
      var w = slideW() + 'px';
      Array.prototype.slice.call(track.children).forEach(function (s) {
        s.style.width = w;
      });
    }

    /* ── Real index (0 … totalSlides-1) from DOM index ── */
    function realIdx() {
      return ((currentIdx - clonesAdded) % totalSlides + totalSlides) % totalSlides;
    }

    /* ── Dots ── */
    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      for (var i = 0; i < totalSlides; i++) {
        var btn = document.createElement('button');
        btn.className = 'll2-dot' + (i === 0 ? ' is-active' : '');
        btn.setAttribute('data-ri', String(i));
        btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dotsWrap.appendChild(btn);
      }
      dotsWrap.querySelectorAll('.ll2-dot').forEach(function (dot) {
        dot.addEventListener('click', function () {
          if (isBusy) return;
          isBusy = true;
          currentIdx = clonesAdded + parseInt(dot.getAttribute('data-ri'), 10);
          applyPos(true);
          updateDots();
          resetAuto();
        });
      });
    }

    function updateDots() {
      if (!dotsWrap) return;
      var ri = realIdx();
      dotsWrap.querySelectorAll('.ll2-dot').forEach(function (d) {
        d.classList.toggle('is-active', parseInt(d.getAttribute('data-ri'), 10) === ri);
      });
    }

    /* ── Navigation ── */
    function goNext() {
      if (isBusy) return;
      isBusy = true;
      currentIdx++;
      applyPos(true);
      updateDots();
    }

    function goPrev() {
      if (isBusy) return;
      isBusy = true;
      currentIdx--;
      applyPos(true);
      updateDots();
    }

    /* ── After each transition: silently jump if in clone zone ── */
    track.addEventListener('transitionend', function (e) {
      if (e.propertyName !== 'transform') return;
      isBusy = false;

      /* Slid past the end → jump back to matching real slide */
      if (currentIdx >= clonesAdded + totalSlides) {
        currentIdx -= totalSlides;
        applyPos(false);
      }
      /* Slid before the start → jump forward to matching real slide */
      if (currentIdx < clonesAdded) {
        currentIdx += totalSlides;
        applyPos(false);
      }
      updateDots();
    });

    /* ── Arrows ── */
    if (prevBtn) prevBtn.addEventListener('click', function () { goPrev(); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goNext(); resetAuto(); });

    /* ── Touch swipe ── */
    var tx = 0, ty = 0;
    track.addEventListener('touchstart', function (e) {
      tx = e.touches[0].clientX;
      ty = e.touches[0].clientY;
    }, { passive: true });
    track.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - tx;
      var dy = e.changedTouches[0].clientY - ty;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
        if (dx < 0) goNext(); else goPrev();
        resetAuto();
      }
    }, { passive: true });

    /* ── Slider autoplay ── */
    function startAuto() {
      if (!doAutoplay) return;
      clearInterval(autoTimer);
      autoTimer = setInterval(goNext, autoInterval);
    }

    function resetAuto() {
      if (!doAutoplay) return;
      clearInterval(autoTimer);
      startAuto();
    }

    /* ── Resize: rebuild clones + widths ── */
    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        var ri = realIdx();
        buildClones();
        applyWidths();
        buildDots();
        currentIdx = clonesAdded + ri;
        applyPos(false);
        updateDots();
      }, 100);
    });

    /* ── Boot ── */
    buildClones();
    applyWidths();
    buildDots();
    applyPos(false);
    startAuto();
  }

  /* ─────────────────────────────────────────
     ENTRY POINT
  ───────────────────────────────────────── */
  function init() {
    if (!sectionEl) return;

    /* Strip autoplay attribute — JS owns all playback */
    getVideos().forEach(function (v) {
      v.removeAttribute('autoplay');
      v.muted = true;
    });

    bindCovers();
    observeSection();

    if (document.getElementById('ll2-track-' + ID)) {
      initSlider();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Theme editor reload */
  document.addEventListener('shopify:section:load', function () {
    sectionEl = document.getElementById('ll2-section-' + ID);
    sectionInView = false;
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    if (sectionEl) {
      sectionEl.querySelectorAll('video').forEach(function (v) {
        delete v.dataset.ll2Bound;
      });
    }
    init();
  });

})();
</script>
