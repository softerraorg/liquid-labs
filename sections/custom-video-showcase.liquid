{% schema %}
{
  "name": "Custom Video Section",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Behind the scenes" },
    { "type": "header", "content": "Section Padding" },
{
  "type": "range",
  "id": "padding_top",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "Padding Top (Desktop)",
  "default": 36
},
{
  "type": "range",
  "id": "padding_bottom",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "Padding Bottom (Desktop)",
  "default": 36
},
{
  "type": "range",
  "id": "padding_top_mobile",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "Padding Top (Mobile)",
  "default": 20
},
{
  "type": "range",
  "id": "padding_bottom_mobile",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "Padding Bottom (Mobile)",
  "default": 20
},
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "video_width",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Video Width",
      "default": 360
    },
    { "type": "color", "id": "background_color", "label": "Background Color" },
    { "type": "header", "content": "Slider Settings" },
    {
      "type": "range",
      "id": "slides_to_show",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides to Show",
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_to_show_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides to Show (Mobile)",
      "default": 2
    },
    { "type": "checkbox", "id": "show_arrows", "label": "Show Navigation Arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show Navigation Dots", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay Slider", "default": false },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Speed",
      "default": 3000
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 10,
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "cover_image", "label": "Cover Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Section",
      "blocks": [{ "type": "video" }, { "type": "video" }, { "type": "video" }]
    }
  ]
}
{% endschema %}

<style>
  #ll-section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
.ll-section {
  padding: 0;
  text-align: center;
  background: radial-gradient(circle at center, #302d3a, #191720), url(/cdn/shop/files/bg.webp?v=1773264135);
  background-size: cover;
  background-position: center;
  background-blend-mode: soft-light;
}

.ll-title {
  font-size: 40px;
  margin: 0 0 40px;
  color: #fff;
}

.ll-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  max-width: 1200px;
  margin: 0 auto;
}

.ll-slider-outer {
  position: relative;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0;
  box-sizing: border-box;
}

.ll-slider-viewport {
  overflow: hidden;
  width: 100%;
}

.ll-slider-track {
  display: flex;
  gap: 20px;
  will-change: transform;
}

.ll-item {
  flex-shrink: 0;
  position: relative;
  border-radius: 10px;
  overflow: hidden;
}

.ll-video-wrapper {
  position: relative;
  width: 100%;
  padding-top: 177.78%;
}

.ll-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ll-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 2;
  transition: opacity 0.4s;
  cursor: pointer;
}

.ll-item.playing .ll-cover {
  opacity: 0;
  pointer-events: none;
}

.ll-arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.6);
  background: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.2s;
}

.ll-arrow:hover {
  background: #fff;
}
.ll-arrows-wrapper {
  display: flex; 
  justify-content: center;
  gap: 10px;
  column-gap: 30px;
  margin-top: 40px;
}

.ll-arrow svg {
  width: 20px;
  height: 20px;
  fill: none;
  stroke: #fff;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  display: block;
}

.ll-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 20px;
  list-style: none;
  padding: 0;
}

.ll-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.ll-slider-viewport {
  overflow: hidden;
  width: 100%;
  -webkit-overflow-scrolling: touch;
  touch-action: pan-y;
}

.ll-video {
  pointer-events: none; /* prevent video from capturing touch on iOS */
}

.ll-cover {
  touch-action: manipulation;
}

.ll-dot.active {
  background: #fff;
  transform: scale(1.3);
}
.ll-arrow {
  -webkit-tap-highlight-color: transparent;
  -webkit-appearance: none;
  cursor: pointer;
  user-select: none;
}
@media screen and (max-width: 749px) {
  #ll-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
}
</style>

<div class="ll-section" id="ll-section-{{ section.id }}">
  <div class="">
    <div class="page-width">
      <h2 class="ll-title">{{ section.settings.title }}</h2>
      {% if section.settings.layout == 'grid' %}
        <div class="ll-grid">
          {% for block in section.blocks %}
            <div class="ll-item" style="width:{{ section.settings.video_width }}px;" {{ block.shopify_attributes }}>
              <div class="ll-video-wrapper">
                {% if block.settings.video %}
                  {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, class: 'll-video' }}
                {% endif %}
                {% if block.settings.cover_image %}
                  <img class="ll-cover" src="{{ block.settings.cover_image | image_url: width: 800 }}" loading="lazy" alt="">
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div> 
      {% else %}
        <div class="ll-slider-outer">
  
         
  
          <div class="ll-slider-viewport">
            <div class="ll-slider-track" id="ll-track-{{ section.id }}">
              {% for block in section.blocks %}
                <div class="ll-item" {{ block.shopify_attributes }}>
                  <div class="ll-video-wrapper">
                    {% if block.settings.video %}
                      {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, class: 'll-video' }}
                    {% endif %}
                    {% if block.settings.cover_image %}
                      <img class="ll-cover" src="{{ block.settings.cover_image | image_url: width: 800 }}" loading="lazy" alt="">
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
  
          {% if section.settings.show_dots %}
            <ul class="ll-dots" id="ll-dots-{{ section.id }}">
              {% for block in section.blocks %}
                <li><button type="button" class="ll-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></button></li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if section.settings.show_arrows %}
            <div class="ll-arrows-wrapper">
              <button type="button" class="ll-arrow ll-arrow-prev" id="ll-prev-{{ section.id }}" aria-label="Previous">
                <svg width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M23.848 13.1275H2.41211M2.41211 13.1275L13.1284 23.8438M2.41211 13.1275L13.1284 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>              
            </button>
            <button type="button" class="ll-arrow ll-arrow-next" id="ll-next-{{ section.id }}" aria-label="Next">
              <svg width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.41211 13.1275H23.848M23.848 13.1275L13.1317 23.8438M23.848 13.1275L13.1317 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>            
            </button>
            </div>
          {% endif %}
        </div>
      {% endif %}
  </div>
  </div>
</div>


<script>
(function(){

  function initSlider(){

    var section = document.getElementById("ll-section-{{ section.id }}");
    if(!section) return;

    var track = section.querySelector("#ll-track-{{ section.id }}");
    if(!track) return;

    var viewport = track.parentElement;
    var originalSlides = Array.from(track.children);
    var totalOriginal = originalSlides.length;

    var desktopShow = {{ section.settings.slides_to_show | json }};
    var mobileShow  = {{ section.settings.slides_to_show_mobile | json }};
    var show = window.innerWidth > 749 ? desktopShow : mobileShow;
    var gap  = 20;

    // --- Clone for infinite loop ---
    var clonesBefore = originalSlides.slice(-show).map(function(s){ return s.cloneNode(true); });
    var clonesAfter  = originalSlides.slice(0, show).map(function(s){ return s.cloneNode(true); });
    clonesBefore.reverse().forEach(function(c){ track.insertBefore(c, track.firstChild); });
    clonesAfter.forEach(function(c){ track.appendChild(c); });

    var allSlides  = Array.from(track.children);
    var realOffset = show;
    var index      = realOffset;

    // --- Smooth lerp engine ---
    var currentX   = 0;   // actual rendered position
    var targetX    = 0;   // where we want to be
    var rafId      = null;
    var LERP       = 0.10; // 0.08–0.12 feels natural; lower = slower/silkier

    var prevBtn = section.querySelector("#ll-prev-{{ section.id }}");
    var nextBtn = section.querySelector("#ll-next-{{ section.id }}");
    var dotsContainer = section.querySelector("#ll-dots-{{ section.id }}");
    var dots = dotsContainer ? Array.from(dotsContainer.querySelectorAll(".ll-dot")) : [];

    function slideWidth(){
      return (viewport.offsetWidth - gap * (show - 1)) / show;
    }

    function resize(){
      var w = slideWidth();
      allSlides.forEach(function(s){ s.style.width = w + "px"; });
    }

    function getOffset(i){
      return i * (slideWidth() + gap);
    }

    // Apply transform directly — no CSS transition, RAF handles smoothness
    function applyTransform(x){
      track.style.transform = "translateX(" + (-x) + "px)";
    }

    // Instant jump (no animation — for infinite-loop wraparound)
    function jumpTo(i){
      index    = i;
      targetX  = getOffset(i);
      currentX = targetX;
      applyTransform(currentX);
    }

    // Smooth move
    function moveTo(i){
      index   = i;
      targetX = getOffset(i);
      updateDots();
      startRAF();
    }

    // RAF loop — lerp currentX toward targetX
    function tick(){
      var diff = targetX - currentX;

      // Snap when close enough to avoid infinite micro-crawl
      if(Math.abs(diff) < 0.3){
        currentX = targetX;
        applyTransform(currentX);
        rafId = null;

        // Infinite-loop wraparound — silent jump after lerp settles
        if(index < realOffset){
          jumpTo(index + totalOriginal);
        } else if(index >= realOffset + totalOriginal){
          jumpTo(index - totalOriginal);
        }
        return;
      }

      currentX += diff * LERP;
      applyTransform(currentX);
      rafId = requestAnimationFrame(tick);
    }

    function startRAF(){
      if(rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tick);
    }

    function realIndex(){
      return ((index - realOffset) % totalOriginal + totalOriginal) % totalOriginal;
    }

    function updateDots(){
      var ri = realIndex();
      dots.forEach(function(dot, i){
        dot.classList.toggle("active", i === ri);
      });
    }

    // Init
    resize();
    track.style.transition = "none"; // no CSS transition — RAF only
    jumpTo(realOffset);

    // --- Arrow buttons (iOS-safe) ---
    function bindBtn(btn, direction){
      if(!btn) return;
      var tapped = false;

      btn.addEventListener("touchstart", function(){
        tapped = false;
      }, { passive: true });

      btn.addEventListener("touchend", function(e){
        e.preventDefault();
        e.stopPropagation();
        tapped = true;
        moveTo(index + direction);
      }, { passive: false });

      btn.addEventListener("click", function(){
        if(tapped){ tapped = false; return; }
        moveTo(index + direction);
      });
    }

    bindBtn(prevBtn, -1);
    bindBtn(nextBtn, +1);

    // --- Dots ---
    dots.forEach(function(dot, i){
      dot.addEventListener("click", function(){
        moveTo(realOffset + i);
      });
    });

    // --- Touch / Swipe (iOS + Android) ---
    var touchStartX     = 0;
    var touchStartY     = 0;
    var touchCurrentX   = 0;
    var touchMoved      = false;
    var isHorizSwipe    = false;
    var dragStartTarget = 0; // targetX at drag start

    viewport.addEventListener("touchstart", function(e){
      touchStartX     = e.changedTouches[0].clientX;
      touchStartY     = e.changedTouches[0].clientY;
      touchCurrentX   = touchStartX;
      touchMoved      = false;
      isHorizSwipe    = false;
      dragStartTarget = targetX;

      // Pause RAF so drag takes full control
      if(rafId){ cancelAnimationFrame(rafId); rafId = null; }
    }, { passive: true });

    viewport.addEventListener("touchmove", function(e){
      var dx = e.changedTouches[0].clientX - touchStartX;
      var dy = e.changedTouches[0].clientY - touchStartY;
      touchCurrentX = e.changedTouches[0].clientX;

      if(!touchMoved){
        touchMoved   = true;
        isHorizSwipe = Math.abs(dx) > Math.abs(dy);
      }

      if(isHorizSwipe){
        e.preventDefault();
        // Live drag — move track in real time for tactile feel
        var dragX = dragStartTarget - dx;
        currentX  = dragX;
        targetX   = dragX;
        applyTransform(currentX);
      }
    }, { passive: false });

    viewport.addEventListener("touchend", function(e){
      var diff = touchStartX - e.changedTouches[0].clientX;

      if(isHorizSwipe){
        // Snap to nearest slide or flick to next/prev
        var w       = slideWidth() + gap;
        var nearest = Math.round(targetX / w);

        // Flick threshold: if fast swipe (> 40px), force next/prev
        if(Math.abs(diff) > 40){
          nearest = diff > 0 ? Math.floor(dragStartTarget / w) + 1
                              : Math.ceil(dragStartTarget / w)  - 1;
        }

        // Clamp to valid range (including clones)
        nearest = Math.max(0, Math.min(allSlides.length - show, nearest));
        moveTo(nearest);
      }
    }, { passive: true });

    // --- Autoplay ---
    {% if section.settings.autoplay %}
    var autoplaySpeed = {{ section.settings.autoplay_speed | json }};
    setInterval(function(){ moveTo(index + 1); }, autoplaySpeed);
    {% endif %}

    // --- Resize ---
    window.addEventListener("resize", function(){
      show = window.innerWidth > 749 ? desktopShow : mobileShow;
      resize();
      jumpTo(index);
    });
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", initSlider);
  } else {
    initSlider();
  }

  document.addEventListener("shopify:section:load", initSlider);

})();
</script>

<script>
(function(){
  var section = document.getElementById('ll-section-{{ section.id }}');
  if (!section) return;
  section.querySelectorAll('.ll-item').forEach(function(item){
    var video = item.querySelector('video');
    var cover = item.querySelector('.ll-cover');
    if (!video || !cover) return;
    video.addEventListener('play',  function(){ item.classList.add('playing'); });
    video.addEventListener('pause', function(){ item.classList.remove('playing'); });
    cover.addEventListener('click', function(){ video.play(); });
  });
})();
</script>
