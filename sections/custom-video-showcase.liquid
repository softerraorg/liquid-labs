{% comment %} {% schema %}
{
  "name": "Custom Video Section",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Behind the scenes" },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top (Desktop)", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom (Desktop)", "default": 36 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top (Mobile)", "default": 20 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom (Mobile)", "default": 20 },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    { "type": "range", "id": "video_width", "min": 200, "max": 600, "step": 10, "unit": "px", "label": "Video Width (Grid)", "default": 360 },
    { "type": "color", "id": "background_color", "label": "Background Color" },
    { "type": "header", "content": "Slider Settings" },
    { "type": "range", "id": "slides_to_show", "min": 1, "max": 5, "step": 1, "label": "Slides to Show", "default": 3 },
    { "type": "range", "id": "slides_to_show_mobile", "min": 1, "max": 3, "step": 1, "label": "Slides to Show (Mobile)", "default": 2 },
    { "type": "checkbox", "id": "show_arrows", "label": "Show Navigation Arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show Navigation Dots", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay Slider", "default": false },
    { "type": "range", "id": "autoplay_speed", "min": 2000, "max": 8000, "step": 500, "unit": "ms", "label": "Autoplay Speed", "default": 3000 }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 10,
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "cover_image", "label": "Cover Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Section",
      "blocks": [{ "type": "video" }, { "type": "video" }, { "type": "video" }]
    }
  ]
}
{% endschema %}

{{- 'splide-core.css' | asset_url | stylesheet_tag -}}

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide-core.min.css"
  media="print"
  onload="this.media='all'"
>

<style>
  #ll-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #ll-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .ll-section {
    padding: 0;
    text-align: center;
    background: radial-gradient(circle at center, #302d3a, #191720), url(/cdn/shop/files/bg.webp?v=1773264135);
    background-size: cover;
    background-position: center;
    background-blend-mode: soft-light;
  }

  .ll-title {
    font-size: 40px;
    margin: 0 0 40px;
    color: #fff;
  }

  /* ── Grid layout ── */
  .ll-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Slider layout ── */
  .ll-slider-outer {
    position: relative;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0;
    box-sizing: border-box;
  }

  /* Splide overrides */
  #ll-section-{{ section.id }} .splide__track {
    overflow: hidden;
  }

  #ll-section-{{ section.id }} .splide__list {
    display: flex;
    align-items: stretch;
  }

  #ll-section-{{ section.id }} .splide__slide {
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
  }

  #ll-section-{{ section.id }} .splide__arrow {
    display: none !important;
  }

  /* Dots */
  #ll-section-{{ section.id }} .splide__pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    list-style: none;
    padding: 0;
    position: relative;
    bottom: unset;
  }

  #ll-section-{{ section.id }} .splide__pagination__page {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 1;
    transition: background 0.2s, transform 0.2s;
  }

  #ll-section-{{ section.id }} .splide__pagination__page.is-active {
    background: #fff;
    transform: scale(1.3);
  }

  /* ── Shared item styles ── */
  .ll-item {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
  }

  .ll-video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 177.78%;
  }

  .ll-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .ll-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    transition: opacity 0.4s;
    cursor: pointer;
    touch-action: manipulation;
  }

  .ll-item.playing .ll-cover {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Arrows ── */
  .ll-arrows-wrapper {
    display: flex;
    justify-content: center;
    gap: 10px;
    column-gap: 30px;
    margin-top: 40px;
  }

  .ll-arrow {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.2s;
    -webkit-tap-highlight-color: transparent;
    -webkit-appearance: none;
    user-select: none;
  }

  .ll-arrow:hover {
    background: #fff;
  }

  .ll-arrow svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #5D5D5D;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }

  /* Slider viewport hidden until Splide ready */
  .ll-slider-outer .splide:not(.is-initialized) .splide__list {
    visibility: hidden;
  }
</style>

<div class="ll-section" id="ll-section-{{ section.id }}">
  <div class="page-width">
    <h2 class="ll-title">{{ section.settings.title }}</h2>

    {% if section.settings.layout == 'grid' %}

      <div class="ll-grid">
        {% for block in section.blocks %}
          <div class="ll-item" style="width:{{ section.settings.video_width }}px;" {{ block.shopify_attributes }}>
            <div class="ll-video-wrapper">
              {% if block.settings.video %}
                {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, class: 'll-video' }}
              {% endif %}
              {% if block.settings.cover_image %}
                <img class="ll-cover" src="{{ block.settings.cover_image | image_url: width: 800 }}" loading="lazy" alt="">
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

    {% else %}

      <div class="ll-slider-outer">

        <div
          class="splide ll-splide"
          id="ll-splide-{{ section.id }}"
        >
          <div class="splide__track">
            <ul class="splide__list">
              {% for block in section.blocks %}
                <li class="splide__slide ll-item" {{ block.shopify_attributes }}>
                  <div class="ll-video-wrapper">
                    {% if block.settings.video %}
                      {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, class: 'll-video' }}
                    {% endif %}
                    {% if block.settings.cover_image %}
                      <img class="ll-cover" src="{{ block.settings.cover_image | image_url: width: 800 }}" loading="lazy" alt="">
                    {% endif %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>

        {% if section.settings.show_arrows %}
          <div class="ll-arrows-wrapper">
            <button type="button" class="ll-arrow ll-arrow-prev" id="ll-prev-{{ section.id }}" aria-label="Previous">
              <svg width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M23.848 13.1275H2.41211M2.41211 13.1275L13.1284 23.8438M2.41211 13.1275L13.1284 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button type="button" class="ll-arrow ll-arrow-next" id="ll-next-{{ section.id }}" aria-label="Next">
              <svg width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.41211 13.1275H23.848M23.848 13.1275L13.1317 23.8438M23.848 13.1275L13.1317 2.41113" stroke="#5D5D5D" stroke-width="4.82283" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {% endif %}

      </div>

    {% endif %}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js" defer></script>

<script>
(function () {

  function initSlider() {

    var section  = document.getElementById('ll-section-{{ section.id }}');
    if (!section) return;

    var splideEl = document.getElementById('ll-splide-{{ section.id }}');
    if (!splideEl) return;

    if (splideEl.dataset.llInit) return;
    splideEl.dataset.llInit = '1';

    if (typeof Splide === 'undefined') {
      setTimeout(initSlider, 100);
      return;
    }

    var desktopShow   = {{ section.settings.slides_to_show | json }};
    var mobileShow    = {{ section.settings.slides_to_show_mobile | json }};
    var showDots      = {{ section.settings.show_dots | json }};
    var doAutoplay    = {{ section.settings.autoplay | json }};
    var autoplaySpeed = {{ section.settings.autoplay_speed | json }};

    var opts = {
      type        : 'loop',
      perPage     : desktopShow,
      perMove     : 1,
      gap         : '20px',
      arrows      : false,
      pagination  : showDots,
      speed       : 500,
      easing      : 'cubic-bezier(0.25, 0.46, 0.45, 0.94)',
      breakpoints : {
        749: {
          perPage : mobileShow,
          gap     : '12px'
        }
      }
    };

    if (doAutoplay) {
      opts.autoplay    = true;
      opts.interval    = autoplaySpeed;
      opts.pauseOnHover = true;
    }

    var splide = new Splide('#ll-splide-{{ section.id }}', opts);
    splide.mount();

    // Wire existing arrow buttons — iOS-safe touchend
    var prevBtn = section.querySelector('#ll-prev-{{ section.id }}');
    var nextBtn = section.querySelector('#ll-next-{{ section.id }}');

    function bindBtn(btn, dir) {
      if (!btn) return;
      var tapped = false;

      btn.addEventListener('touchstart', function () {
        tapped = false;
      }, { passive: true });

      btn.addEventListener('touchend', function (e) {
        e.preventDefault();
        e.stopPropagation();
        tapped = true;
        splide.go(dir);
      }, { passive: false });

      btn.addEventListener('click', function () {
        if (tapped) { tapped = false; return; }
        splide.go(dir);
      });
    }

    bindBtn(prevBtn, '<');
    bindBtn(nextBtn, '>');

    // Bind video cover play after Splide clones slides
    splide.on('mounted', function () {
      bindVideos(section);
    });
  }

  function bindVideos(section) {
    section.querySelectorAll('.ll-item').forEach(function (item) {
      var video = item.querySelector('video');
      var cover = item.querySelector('.ll-cover');
      if (!video || !cover) return;
      // Avoid double-binding on clones
      if (cover.dataset.llBound) return;
      cover.dataset.llBound = '1';
      video.addEventListener('play',  function () { item.classList.add('playing'); });
      video.addEventListener('pause', function () { item.classList.remove('playing'); });
      cover.addEventListener('click', function () { video.play(); });
    });
  }

  function init() {
    if (typeof Splide === 'undefined') {
      var s = document.querySelector('script[src*="splide"]');
      if (s) {
        s.addEventListener('load', initSlider);
      } else {
        setTimeout(initSlider, 300);
      }
    } else {
      initSlider();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', function () {
    var el = document.getElementById('ll-splide-{{ section.id }}');
    if (el) delete el.dataset.llInit;
    init();
  });

})();
</script> {% endcomment %}


