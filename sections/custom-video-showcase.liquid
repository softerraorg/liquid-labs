    #vs-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #vs-{{ section.id }} .vs-title {
    font-size: 40px;
    margin: 0 0 40px;
    color: #fff;
  }

  /* ── Grid ── */
  #vs-{{ section.id }} .vs-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Scroll-snap slider ──
     Using native browser scroll instead of CSS transforms.
     This is the most iOS-compatible slider approach:
     scrolled-away slides are truly off-screen, so
     IntersectionObserver and iOS autoplay both work correctly. */
  #vs-{{ section.id }} .vs-outer {
    max-width: 1300px;
    margin: 0 auto;
    overflow: hidden;          /* clips scrolled-away slides */
  }

  #vs-{{ section.id }} .vs-track {
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-snap-stop: always;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: none;
    scrollbar-width: none;
  }
  #vs-{{ section.id }} .vs-track::-webkit-scrollbar { display: none; }

  #vs-{{ section.id }} .vs-slide {
    flex-shrink: 0;
    scroll-snap-align: start;
    padding: 0 10px;
    box-sizing: border-box;
    /* Width is set in px by JS */
  }
  @media (max-width: 749px) {
    #vs-{{ section.id }} .vs-slide { padding: 0 6px; }
  }

  /* ── Shared item ── */
  #vs-{{ section.id }} .vs-item {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
  }
  #vs-{{ section.id }} .vs-video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 177.78%;
  }
  #vs-{{ section.id }} .vs-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  #vs-{{ section.id }} .vs-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    transition: opacity 0.4s;
    cursor: pointer;
    touch-action: manipulation;
  }
  #vs-{{ section.id }} .vs-item.playing .vs-cover {
    opacity: 0;
    pointer-events: none;
  }

  /* Hide iOS native play-button overlay */
  #vs-{{ section.id }} video::-webkit-media-controls               { display: none !important; }
  #vs-{{ section.id }} video::-webkit-media-controls-start-playback-button {
    display: none !important;
    -webkit-appearance: none;
  }

  /* ── Arrows ── */
  #vs-{{ section.id }} .vs-arrows {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-top: 40px;
  }
  #vs-{{ section.id }} .vs-arrow {
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    background: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    transition: background 0.2s;
    -webkit-tap-highlight-color: transparent;
    -webkit-appearance: none;
    user-select: none;
  }
  #vs-{{ section.id }} .vs-arrow:hover { background: #f0f0f0; }
  #vs-{{ section.id }} .vs-arrow svg {
    width: 20px; height: 20px;
    fill: none; stroke: #5D5D5D;
    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
    display: block;
  }

  /* ── Dots ── */
  #vs-{{ section.id }} .vs-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    padding: 0;
  }
  #vs-{{ section.id }} .vs-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
