    {% else %}

      <div class="vs-outer" id="vs-outer-{{ section.id }}">
        <div class="vs-track" id="vs-track-{{ section.id }}">
          {% for block in section.blocks %}
            <div class="vs-slide" {{ block.shopify_attributes }}>
              <div class="vs-item">
                <div class="vs-video-wrapper">
                  {% if block.settings.video %}
                    {% if block.settings.video.preview_image %}
                      {% assign poster_url = block.settings.video.preview_image | image_url: width: 1200 %}
                      {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, poster: poster_url, class: 'vs-video' }}
                    {% else %}
                      {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, class: 'vs-video' }}
                    {% endif %}
                  {% endif %}
                  {% if block.settings.cover_image %}
                    <img class="vs-cover" src="{{ block.settings.cover_image | image_url: width: 1200 }}" loading="eager" fetchpriority="high" decoding="sync" alt="">
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_arrows %}
        <div class="vs-arrows">
          <button type="button" class="vs-arrow" id="vs-prev-{{ section.id }}" aria-label="Previous">
            <svg viewBox="0 0 27 27"><path d="M23.848 13.128H2.412M2.412 13.128l10.716 10.716M2.412 13.128l10.716-10.717" stroke-width="4.82" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button type="button" class="vs-arrow" id="vs-next-{{ section.id }}" aria-label="Next">
            <svg viewBox="0 0 27 27"><path d="M2.412 13.128H23.848M23.848 13.128L13.132 23.844M23.848 13.128L13.132 2.411" stroke-width="4.82" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      {% endif %}

      {% if section.settings.show_dots %}
        <div class="vs-dots" id="vs-dots-{{ section.id }}"></div>
      {% endif %}

    {% endif %}
  </div>
</div>

<script>
(function () {
  var SID = '{{ section.id }}';

  function run(sectionEl) {
    var outerEl = sectionEl.querySelector('#vs-outer-' + SID);
    var trackEl = sectionEl.querySelector('#vs-track-' + SID);
    if (!outerEl || !trackEl) {
      /* Grid layout — just bind videos */
      bindAllVideos(sectionEl);
      return;
    }

    var dotsWrap  = sectionEl.querySelector('#vs-dots-' + SID);
    var prevBtn   = sectionEl.querySelector('#vs-prev-' + SID);
    var nextBtn   = sectionEl.querySelector('#vs-next-' + SID);
    var desktopPer  = {{ section.settings.slides_to_show | json }};
    var mobilePer   = {{ section.settings.slides_to_show_mobile | json }};
    var doAutoplay  = {{ section.settings.autoplay | json }};
    var autoInterval= {{ section.settings.autoplay_speed | json }};

    /* Real slides captured before any cloning */
    var realSlides  = Array.prototype.slice.call(trackEl.children);
    var total       = realSlides.length;
    var clonesAdded = 0;
    var isJumping   = false;
    var autoTimer   = null;

    function pp()  { return window.innerWidth <= 749 ? mobilePer : desktopPer; }
    function sw()  { return outerEl.offsetWidth / pp(); }

    /* ── Build infinite-loop clones ──
       Clones are real scrolled positions — NOT CSS transforms.
       IntersectionObserver (default viewport root) correctly
       detects them as off-screen because overflow:hidden clips them. */
    function buildClones() {
      Array.prototype.slice.call(trackEl.querySelectorAll('[data-vs-clone]'))
        .forEach(function (c) { trackEl.removeChild(c); });

      clonesAdded = Math.min(pp(), total);

      /* Prepend: copies of the last N real slides */
      var frag = document.createDocumentFragment();
      for (var i = total - clonesAdded; i < total; i++) {
        var c = realSlides[i].cloneNode(true);
        c.setAttribute('data-vs-clone', '1');
        c.setAttribute('aria-hidden', 'true');
        frag.appendChild(c);
      }
      trackEl.insertBefore(frag, trackEl.firstChild);

      /* Append: copies of the first N real slides */
      for (var j = 0; j < clonesAdded; j++) {
        var c2 = realSlides[j].cloneNode(true);
        c2.setAttribute('data-vs-clone', '1');
        c2.setAttribute('aria-hidden', 'true');
        trackEl.appendChild(c2);
      }

      /* Ensure every clone video has the right attributes */
      Array.prototype.slice.call(trackEl.querySelectorAll('[data-vs-clone] video'))
        .forEach(function (v) {
          v.setAttribute('autoplay', '');
          v.setAttribute('muted', '');
          v.setAttribute('playsinline', '');
          v.muted = true;
          delete v.dataset.vsBound;
        });
    }

    function applyWidths() {
      var w = sw() + 'px';
      Array.prototype.slice.call(trackEl.children)
        .forEach(function (s) { s.style.width = w; });
    }

    /* Scroll to first real slide (no animation) */
    function scrollToReal(ri) {
      isJumping = true;
      trackEl.scrollLeft = (clonesAdded + ri) * sw();
      /* Reset flag after browser has processed the scroll */
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { isJumping = false; });
      });
    }

    /* Current real index from scrollLeft */
    function currentRealIdx() {
      var idx = Math.round(trackEl.scrollLeft / sw()) - clonesAdded;
      return ((idx % total) + total) % total;
    }

    /* ── Dots ── */
    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      for (var i = 0; i < total; i++) {
        var btn = document.createElement('button');
        btn.className = 'vs-dot' + (i === 0 ? ' is-active' : '');
        btn.setAttribute('data-ri', String(i));
        btn.setAttribute('aria-label', 'Slide ' + (i + 1));
        dotsWrap.appendChild(btn);
      }
      dotsWrap.querySelectorAll('.vs-dot').forEach(function (dot) {
        dot.addEventListener('click', function () {
          var ri = parseInt(dot.getAttribute('data-ri'), 10);
          trackEl.scrollTo({ left: (clonesAdded + ri) * sw(), behavior: 'smooth' });
          resetAuto();
        });
      });
    }

    function updateDots() {
      if (!dotsWrap) return;
      var ri = currentRealIdx();
      dotsWrap.querySelectorAll('.vs-dot').forEach(function (d) {
        d.classList.toggle('is-active', parseInt(d.getAttribute('data-ri'), 10) === ri);
      });
    }

    /* ── Infinite loop: detect when scrolled into clone territory ── */
    var scrollTimer;
    trackEl.addEventListener('scroll', function () {
      if (isJumping) return;
      updateDots();
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        if (isJumping) return;
        var s      = trackEl.scrollLeft;
        var minPos = clonesAdded * sw();
        var maxPos = (clonesAdded + total - pp()) * sw();

        if (s < minPos - 2) {
          /* Scrolled into before-clones → jump forward by totalSlides */
          isJumping = true;
          trackEl.scrollLeft = s + total * sw();
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { isJumping = false; });
          });
        } else if (s > maxPos + 2) {
          /* Scrolled into after-clones → jump back by totalSlides */
          isJumping = true;
          trackEl.scrollLeft = s - total * sw();
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { isJumping = false; });
          });
        }
      }, 80);
    }, { passive: true });

    /* ── Arrows ── */
    if (prevBtn) prevBtn.addEventListener('click', function () {
      trackEl.scrollBy({ left: -sw(), behavior: 'smooth' });
      resetAuto();
    });
    if (nextBtn) nextBtn.addEventListener('click', function () {
      trackEl.scrollBy({ left: sw(), behavior: 'smooth' });
      resetAuto();
    });

    /* ── Slider autoplay ── */
    function startAuto() {
      if (!doAutoplay) return;
      clearInterval(autoTimer);
      autoTimer = setInterval(function () {
        trackEl.scrollBy({ left: sw(), behavior: 'smooth' });
      }, autoInterval);
    }
    function resetAuto() {
      if (!doAutoplay) return;
      clearInterval(autoTimer);
      startAuto();
    }

    /* ── Resize ── */
    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        var ri = currentRealIdx();
        buildClones();
        applyWidths();
        buildDots();
        bindAllVideos(sectionEl);
        scrollToReal(ri);
        updateDots();
      }, 100);
    });

    /* ── Boot slider ── */
    buildClones();
    applyWidths();
    buildDots();
    bindAllVideos(sectionEl);

    /* Set initial scroll position after layout is painted */
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        scrollToReal(0);
        startAuto();
      });
    });
  }

  /* ─────────────────────────────────────────
     VIDEO BINDING
     Per-video IntersectionObserver uses the
     default viewport root, which correctly
     accounts for the overflow:hidden clip on
     .vs-outer. Off-screen slides are genuinely
     outside the viewport → play() is ONLY called
     on truly visible videos — the iOS requirement.
  ───────────────────────────────────────── */
  function bindAllVideos(sectionEl) {
    if (!sectionEl) return;
    Array.prototype.slice.call(sectionEl.querySelectorAll('video'))
      .forEach(function (v) { bindVideo(v); });
  }

  function bindVideo(v) {
    if (v.dataset.vsBound) return;
    v.dataset.vsBound = '1';
    v.muted = true;

    /* Find parent .vs-item for the playing CSS class */
    var item = v.parentNode;
    while (item && !item.classList.contains('vs-item')) item = item.parentNode;
    if (item) {
      v.addEventListener('playing', function () { item.classList.add('playing'); });
      v.addEventListener('pause',   function () { item.classList.remove('playing'); });
      var cover = item.querySelector('.vs-cover');
      if (cover) {
        cover.addEventListener('click', function () {
          v.muted = true;
          var p = v.play();
          if (p && p.catch) p.catch(function () {});
        });
      }
    }

    /* IntersectionObserver with viewport root.
       overflow:hidden on .vs-outer means any video scrolled
       off the side has zero intersection area → not intersecting.
       This is exactly when we should pause and not play. */
    var io = new IntersectionObserver(function (entries) {
      var e = entries[0];
      if (e.isIntersecting) {
        v.muted = true;
        var p = v.play();
        if (p && p.catch) {
          p.catch(function () {
            /* iOS may need the video to be ready first */
            function onReady() {
              v.removeEventListener('canplay', onReady);
              v.muted = true;
              var p2 = v.play();
              if (p2 && p2.catch) p2.catch(function () {});
            }
            v.addEventListener('canplay', onReady);
          });
        }
      } else {
        if (!v.paused) v.pause();
      }
    }, { threshold: 0.3 });

    io.observe(v);
  }

  /* ── Entry point ── */
  function init() {
    var sectionEl = document.getElementById('vs-' + SID);
    if (!sectionEl) return;
    /* Reset bound flags in case of re-init */
    sectionEl.querySelectorAll('video').forEach(function (v) {
      delete v.dataset.vsBound;
    });
    run(sectionEl);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', init);

})();
</script>