          <div class="vs-item" style="width:{{ section.settings.video_width }}px;" {{ block.shopify_attributes }}>
            <div class="vs-video-wrapper">
              {% if block.settings.video %}
                {% if block.settings.video.preview_image %}
                  {% assign poster_url = block.settings.video.preview_image | image_url: width: 1200 %}
                  {{ block.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, poster: poster_url, class: 'vs-video' }}
