{% style %}
  .ll-founding-member-section {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  .ll-fm-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ll-fm-title {
    font-size: 46px;
    font-weight: 300;
    text-align: center;
    color: {{ section.settings.text_color }};
    margin: 0 0 50px 0;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  /* Main Flex Layout */
  .ll-fm-layout {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: stretch;
    gap: 20px;
  }

  /* Columns */
  .ll-fm-col {
    display: flex;
    flex-direction: column;
  }

  .ll-fm-col-side {
    flex: 1;
    z-index: 2;
  }

  .ll-fm-col-center {
    flex: 0 0 35%;
    max-width: 450px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }

  .ll-fm-main-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Feature Items (Blocks) */
  .ll-fm-item {
    display: flex;
    align-items: var(--align);
    margin-top: var(--mt-desk);
    margin-bottom: var(--mb-desk);
    gap: 15px;
  }

  .ll-fm-item-left {
    flex-direction: column;
    justify-content: flex-end;
  }

  .ll-fm-item-right {
    flex-direction: row;
    justify-content: flex-start;
  }

  .ll-fm-text {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  .ll-fm-item-left .ll-fm-text {
    text-align: right;
  }

  .ll-fm-item-right .ll-fm-text {
    text-align: left;
  }

  .ll-fm-line {
    width: var(--w-desk);
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Button */
  .ll-fm-btn-wrapper {
    margin-top: 50px;
    text-align: center;
  }

  .ll-fm-btn {
    display: inline-block;
    background: linear-gradient(180deg, #427DFF 0%, #1A55D6 100%);
    border: 1px solid #7FAEFF;
    box-shadow: 0px 4px 20px rgba(66, 125, 255, 0.4);
    color: #FFFFFF;
    font-size: 18px;
    font-weight: 600;
    padding: 16px 56px;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ll-fm-btn:hover {
    opacity: 0.9;
    box-shadow: 0px 6px 25px rgba(66, 125, 255, 0.6);
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 900px) {
    .ll-fm-col-center {
      flex: 0 0 45%;
    }
  }

  @media screen and (max-width: 749px) {
    .ll-founding-member-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .ll-fm-title {
      font-size: 26px;
      margin-bottom: 30px;
    }

    /* Keep side-by-side but tighten gaps */
    .ll-fm-layout {
      gap: 10px;
    }

    .ll-fm-col-center {
      flex: 0 0 40%;
    }

    .ll-fm-item {
      gap: 8px;
      margin-top: var(--mt-mob);
      margin-bottom: var(--mb-mob);
    }

    .ll-fm-text {
      font-size: 13px;
    }

    .ll-fm-line {
      width: var(--w-mob);
    }

    .ll-fm-btn-wrapper {
      margin-top: 30px;
    }

    .ll-fm-btn {
      font-size: 16px;
      padding: 14px 40px;
      width: 100%;
      max-width: 300px;
    }
  }
{% endstyle %}

<div class="ll-founding-member-section gradient">
  <div class="ll-fm-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="ll-fm-title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ll-fm-layout">
      
      {%- comment -%} ── LEFT COLUMN ── {%- endcomment -%}
      <div class="ll-fm-col ll-fm-col-side ll-fm-left">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'left' -%}
            <div class="ll-fm-item ll-fm-item-left" {{ block.shopify_attributes }}
                 style="
                   --align: {{ block.settings.vertical_alignment }}; 
                   --mt-desk: {{ block.settings.margin_top_desktop }}px; 
                   --mb-desk: {{ block.settings.margin_bottom_desktop }}px; 
                   --mt-mob: {{ block.settings.margin_top_mobile }}px; 
                   --mb-mob: {{ block.settings.margin_bottom_mobile }}px;
                   --w-desk: {{ block.settings.line_width_desktop }}px;
                   --w-mob: {{ block.settings.line_width_mobile }}px;
                 ">
              
              {%- if block.settings.text != blank -%}
                <p class="ll-fm-text">{{ block.settings.text | newline_to_br }}</p>
              {%- endif -%}

              {%- if block.settings.line_image != blank -%}
                {{ block.settings.line_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'll-fm-line', alt: block.settings.line_image.alt | escape }}
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} ── CENTER COLUMN (IMAGE) ── {%- endcomment -%}
      <div class="ll-fm-col ll-fm-col-center">
        {%- if section.settings.main_image != blank -%}
          {{ section.settings.main_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'll-fm-main-image', alt: section.settings.main_image.alt | escape }}
        {%- endif -%}
      </div>

      {%- comment -%} ── RIGHT COLUMN ── {%- endcomment -%}
      <div class="ll-fm-col ll-fm-col-side ll-fm-right">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'right' -%}
            <div class="ll-fm-item ll-fm-item-right" {{ block.shopify_attributes }}
                 style="
                   --align: {{ block.settings.vertical_alignment }}; 
                   --mt-desk: {{ block.settings.margin_top_desktop }}px; 
                   --mb-desk: {{ block.settings.margin_bottom_desktop }}px; 
                   --mt-mob: {{ block.settings.margin_top_mobile }}px; 
                   --mb-mob: {{ block.settings.margin_bottom_mobile }}px;
                   --w-desk: {{ block.settings.line_width_desktop }}px;
                   --w-mob: {{ block.settings.line_width_mobile }}px;
                 ">
              
              {%- if block.settings.line_image != blank -%}
                {{ block.settings.line_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'll-fm-line', alt: block.settings.line_image.alt | escape }}
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="ll-fm-text">{{ block.settings.text | newline_to_br }}</p>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} ── BUTTON ── {%- endcomment -%}
    {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
      <div class="ll-fm-btn-wrapper">
        <a href="{{ section.settings.button_link }}" class="ll-fm-btn">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "LL Founding Member",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Become a founding member"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Center Product Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Pre-Order Now!"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111115"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Column Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Feature description"
        },
        {
          "type": "image_picker",
          "id": "line_image",
          "label": "Line/Angle Image",
          "info": "Upload the transparent line exported from Figma."
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "Vertical Alignment with Image",
          "options": [
            { "value": "flex-start", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Bottom" }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Line Width"
        },
        {
          "type": "range",
          "id": "line_width_desktop",
          "label": "Line Width (Desktop)",
          "min": 20,
          "max": 300,
          "step": 5,
          "unit": "px",
          "default": 100
        },
        {
          "type": "range",
          "id": "line_width_mobile",
          "label": "Line Width (Mobile)",
          "min": 10,
          "max": 150,
          "step": 2,
          "unit": "px",
          "default": 40
        },
        {
          "type": "header",
          "content": "Vertical Spacing (Desktop)"
        },
        {
          "type": "range",
          "id": "margin_top_desktop",
          "label": "Margin Top",
          "min": -100,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_desktop",
          "label": "Margin Bottom",
          "min": -100,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 60
        },
        {
          "type": "header",
          "content": "Vertical Spacing (Mobile)"
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "label": "Margin Top",
          "min": -50,
          "max": 100,
          "step": 5,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "label": "Margin Bottom",
          "min": -50,
          "max": 100,
          "step": 5,
          "unit": "px",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LL Founding Member",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "position": "left",
            "text": "20% off entire purchase",
            "vertical_alignment": "flex-end"
          }
        },
        {
          "type": "feature",
          "settings": {
            "position": "left",
            "text": "Risk free\ncancellation at\nany time",
            "vertical_alignment": "flex-start"
          }
        },
        {
          "type": "feature",
          "settings": {
            "position": "right",
            "text": "Priority shipping",
            "vertical_alignment": "flex-end"
          }
        },
        {
          "type": "feature",
          "settings": {
            "position": "right",
            "text": "$5 off your second\npurchase",
            "vertical_alignment": "flex-start"
          }
        }
      ]
    }
  ]
}
{% endschema %}